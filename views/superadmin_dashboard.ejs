<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, intial-scale=1.0">
        <title>Adminstator Dashboard | Let's Connect</title>
        <style>
            :root { --jag-red: #bf0028; --jag-blue: #00205b; }
            body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; margin: 0; padding: 20px; }
            h1 { color: var(--jag-blue); border-bottom: 3px solid var(--jag-red); padding-bottom: 10px; }
            .dashboard-container { max-width: 1000px; margin: 0 auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        
            table { width: 100%; border-collapse: collapse; margin-top: 20px; }
            th { background-color: var(--jag-blue); color: white; text-align: left; padding: 12px; }
            td { padding: 12px; border-bottom: 1px solid #ddd; }
            tr:hover { background-color: #f9f9f9; }

            .btn { padding: 8px 15px; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; text-decoration: none; display: inline-block; }
            .approve-btn { background-color: #28a745; color: white; margin-right: 5px; }
            .deny-btn { background-color: var(--jag-red); color: white; }
            .btn:hover { opacity: 0.8; }
        
            .empty-state { text-align: center; color: #666; padding: 40px; }
            .nav-bar { display: flex; justify-content: space-between; align-items: center; }
            .logout-link { color: var(--jag-red); font-weight: bold; }
        </style>
    </head>
    <body>
        <div class="dashboard-container">
            <div class="nav-bar">
                <h1>Club Approval Queue</h1>
                <a href="/logout" class="logout-link">Logout</a>
            </div>

            <% if (clubs.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Club Name</th>
                            <th>Sponsor</th>
                            <th>Moderator</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% clubs.forEach(club => { %>
                            <tr>
                                <td><strong><%= club.club_name %></strong></td>
                                <td><%= club.faculty_sponsor %></td>
                                <td><%= club.moderator_name %></td>
                                <td>
                                    <form action="/admin/approve/<%= club.club_id %>" method="POST" style="display:inline;">
                                        <button type="submit" class="btn approve-btn">Approve</button>
                                    </form>
                                    <form action="/admin/deny/<%= club.club_id %>" method="POST" style="display:inline;">
                                        <button type="submit" class="btn deny-btn">Deny</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="empty-state">
                    <h3>All Caught Up!</h3>
                    <p>There are no pending club requests at this time.</p>
                </div>
            <% } %>
        </div>
    </body>
</html>