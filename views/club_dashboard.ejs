<!DOCTYPE html>
<html>
    <head>
        <title><%= club.club_name %> Dashboard</title>
        <link rel="stylesheet" href="/css/style.css">
        <style>
            body { font-family: 'Segoe UI', sans-serif; background-color: #f4f4f9; margin: 0; padding: 0; }
            .container { max-width: 800px; margin: 40px auto; padding: 0 20px; }

            .tab-container { display: flex; gap: 5px; margin-bottom: 0; }
            .tab-btn {
                background: #e0e0e0; border: none; padding: 12px 25px;
                cursor: pointer; border-radius: 10px 10px 0 0;
                font-weight: bold; transition: 0.3s; color: #555;
            }
            .tab-btn.active { background: white; color: #bf0028; border-bottom: 2px solid #bf0028; }
            .tab-btn:hover:not(.active) { background: #dcdcdc; }

            .post-box { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
            textarea { width: 100%; height: 100px; margin-top: 10px; padding: 10px; border-radius: 5px; border: 1px solid #ccc; }
            .btn { background: #bf0028; color: white; padding: 10 px 20px; border: none; border-radius: 5px; cursor: pointer; margin-top: 10px; }
            .btn:hover { background: #8e001e; }
            .btn-secondary { background: #333; }

            table { width: 100%; border-collapse: collapse; margin-top: 15px; }
            th, td { text-align: left; padding: 12px; border-bottom: 1px solid #eee; }
            .danger-zone { border: 1px solid #ff0000; }

            .hidden { display: none; }
        </style>
    </head>
    <body>
        <header style="background: #bf0028; color: white; padding: 20px; text-align: center;">
            <h1>Welcome, Admin of <%= club.club_name %></h1>
            <nav>
                <a href="/" style="color: white; text-decoration: none;">View Public Feed</a> | 
                <a href="/logout" style="color: white; text-decoration: none;">Logout</a>
            </nav>
        </header>

        <div class="container">
            <div class="tab-container">
                <button class="tab-btn active" onclick="showTab(event, 'updates')">Manage Feed</button>
                <button class="tab-btn" onclick="showTab(event, 'connections')">Student Connections</button>
                <button class="tab-btn" onclick="showTab(event, 'settings')">Admin Settings</button>
            </div>

            <div id="updates" class="tab-content">
                <div class="post-box">
                    <h3>Post a New Update</h3>
                    <form action="/club/post" method="POST" enctype="multipart/form-data">
                        <textarea name="content" placeholder="e.g., We are having a meeting a the Student Center at 5 PM!" required></textarea>

                        <label for="image">Add a Photo (Optional):</label>
                        <input type="file" name="image" accept="image/*">

                        <button type="submit" class="btn">Post</button>
                    </form>

                    <hr style="margin: 30px 0; border: 0; border-top: 1px solid #eee;">

                    <h3>Manage Your Posts</h3>
                    <% if (posts && posts.length > 0) { %>
                        <table>
                            <thead>
                                <tr>
                                    <th>Content</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% posts.forEach(p => { %>
                                <tr id="post-row-<%= p.post_id %>">
                                    <td style="font-size: 0.9em;"><%= p.content.substring(0, 40) %>...</td>
                                    <td><%= new Date(p.created_at).toLocaleDateString() %></td>
                                    <td>
                                        <button onclick="editPost('<%= p.post_id %>', '<%= p.content %>')" style="background:#555; color:white; border:none; padding:5px 10px; border-radius: 3px; cursor:pointer;">Edit</button>
                                        <button onclick="deletePost('<%= p.post_id %>')" class="delete-btn" style="background:#bf0028; color:white; border:none; padding:5px 10px; border-radius:3px; cursor:pointer;">Delete</button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p style="color: #888; font-style: italic;">No updates posted yet.</p>
                    <% } %>
                </div>
            </div>

            <div id="connections" class="tab-content hidden">
                <div class="post-box">
                    <h3>Student Connections</h3>
                    <p>These students have clicked <strong>"Connect"</strong> to show interest in your club.</p>
                    <% if (connections && connections.length > 0) { %>
                        <table>
                            <thead>
                                <tr><th>Name</th><th>Email</th></tr>
                            </thead>
                            <tbody>
                                <% connections.forEach(student => { %>
                                    <tr>
                                        <td><%= student.full_name %></td>
                                        <td><a href="mailto:<%= student.email %>" style="color: #bf0028;"><%= student.email %></a></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p style="color: #888; font-style: italic;">No connections yet.</p>
                    <% } %>
                </div>
            </div>

            <div id="settings" class="tab-content hidden">
                <div class="post-box" style="margin-bottom: 20px;">
                    <h3>Club Personnel</h3>
                    <p><strong>Adminstrator:</strong> <%= user.full_name %></p>
                    <p style="font-size: 0.85em; color: #666;">
                        As the primary Admin, you have full authority to manage posts, view student connections, and transfer ownership of this dashboard.
                    </p>
                </div>

                <div class="post-box danger-zone">
                    <h3 style="color: #bf0028;">Transfer Ownership</h3>
                    <p>Enter the email of the new Admin to transfer this club dashboard to them.</p>
                    <form action="/club/transfer-ownership" method="POST">
                        <input type="email" name="newAdminEmail" placeholder="New Admin's Email" required
                            style="width: 70%; padding: 10px; border-radius: 5px; border: 1px solid #ccc;">
                        <button type="submit" class="btn btn-secondary">Transfer Keys</button>
                    </form>
                </div>
            </div>
        </div>

            <script>
                // Tab Switching Logic
                function showTab(evt, tabId) {
                    // Hide all contents
                    document.querySelectorAll('.tab-content').forEach(content => content.classList.add('hidden'));

                    // Deactivate all buttons
                    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));

                    document.getElementById(tabId).classList.remove('hidden');
                    evt.currentTarget.classList.add('active');
                }

                //Delete Post Logic
                async function deletePost(postId) {
                    if (!confirm("Are you sure you want to delete this post?")) return;

                    const response = await fetch(`/club/post/delete/${postId}`, { method: 'POST' });
                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        alert("Failed to delete post.");
                    }
                }

                async function editPost(postId, currentContent) {
                    const newContent = prompt("Edit your updates:", currentContent);

                    if (newContent && newContent !== currentContent) {
                        const response = await fetch(`/club/post/edit/${postId}`, {
                            method: 'POST', 
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ content: newContent })
                        });
                        const result = await response.json();
                        if (result.success) {
                            location.reload();
                        } else {
                            alert("Failed to update post.");
                        }
                    }
                }

                async function transferClub() {
                    const email = prompt("Enter the South Alabama email of the new Club Admin:");

                    if (email) {
                        if (!confirm(`Are you SURE? You will lose admin access and be logged out immediately.`)) return;

                        const response = await fetch('/club/transfer', {
                            method: 'POST',
                            headers: { 'Content-Type' : 'application/json' },
                            body: JSON.stringify({ newAdminEmail: email })
                        });

                        const result = await response.json();

                        if (result.success) {
                            alert(result.message);
                            window.location.href = '/login.html';
                        } else {
                            alert(result.message);
                        }
                    }
                }
            </script>
        </div>
    </body>
</html>